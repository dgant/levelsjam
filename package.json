{
  "name": "levelsjam",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:bg": "node scripts/dev-server.cjs start",
    "dev:bg:status": "node scripts/dev-server.cjs status",
    "dev:bg:stop": "node scripts/dev-server.cjs stop",
    "build": "node scripts/build-runtime-props.mjs && node scripts/sync-maze-runtime-data.cjs && vite build",
    "build:assets:props": "node scripts/build-runtime-props.mjs",
    "build:assets:minotaur": "node scripts/simplify-minotaur.mjs",
    "ensure:mazes": "node scripts/ensure-mazes.cjs",
    "export:maze-probes": "node scripts/export-maze-reflection-artifacts.cjs",
    "preview": "npm run build:pages && node scripts/serve-root.cjs 4173",
    "test:unit": "node scripts/run-unit-tests.cjs",
    "test:smoke:runner": "playwright test tests/smoke.spec.cjs",
    "test:smoke": "npm run build:pages && playwright test tests/smoke.spec.cjs",
    "test:render:integration:runner": "playwright test tests/render-integration.spec.cjs",
    "test:render:integration": "npm run build:pages && playwright test tests/render-integration.spec.cjs",
    "test:probe-occlusion:runner": "playwright test tests/reflection-probe-occlusion.spec.cjs",
    "test:probe-occlusion": "npm run build:pages && playwright test tests/reflection-probe-occlusion.spec.cjs",
    "test:perf:runner": "playwright test tests/perf.spec.cjs",
    "test:perf": "npm run build:pages && playwright test tests/perf.spec.cjs",
    "build:pages": "npm run build && node scripts/sync-pages.cjs",
    "bench:startup": "node scripts/benchmark-startup.cjs",
    "bench:tests": "node scripts/benchmark-tests.cjs",
    "test:maze:runner": "node scripts/run-maze-tests.cjs"
  },
  "dependencies": {
    "@react-three/fiber": "^9.3.0",
    "@react-three/postprocessing": "^3.0.4",
    "postprocessing": "^6.37.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.52.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "4.4.1",
    "jimp": "^1.6.1",
    "meshoptimizer": "^1.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.2",
    "vite": "5.4.21"
  }
}
